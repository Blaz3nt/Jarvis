# === Required ===
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# === Claude Model (default: haiku for low cost) ===
# Options: claude-haiku-4-5-20251001 (cheapest), claude-sonnet-4-20250514 (balanced), claude-opus-4-20250514 (smartest)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# === Token Budget ===
# Max conversation messages to keep in memory (lower = cheaper)
MAX_HISTORY_MESSAGES=20

# === Whisper (local, no API cost) ===
WHISPER_MODEL=tiny.en

# === Audio ===
MIC_DEVICE_INDEX=0
MIC_SAMPLE_RATE=16000
ENERGY_THRESHOLD=1000
RECORD_TIMEOUT=2
PHRASE_TIMEOUT=3

# === TTS ===
TTS_ENABLED=true
TTS_VOICE=en-US-GuyNeural

# === Hotwords (comma-separated) ===
HOT_WORDS=jarvis

# === Conversation Mode ===
# After wake word, how long to stay attentive with no speech (seconds)
CONVERSATION_TIMEOUT=30
# Seconds of silence to detect end of a sentence
CONVERSATION_PAUSE=2.0
# Wake word sensitivity (0.0-1.0, higher = triggers more easily)
WAKE_WORD_SENSITIVITY=0.5
# Grace period — after conversation ends, still half-listen for this long.
# If you speak during grace, Jarvis re-engages without the wake word.
GRACE_PERIOD=60

# === Email (IMAP) — Optional ===
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_ADDRESS=
EMAIL_PASSWORD=

# === Documents — Optional ===
# Mount your documents folder to this path in docker-compose.yml
DOCUMENTS_PATH=/documents

# === Reminders ===
REMINDERS_DB=/data/reminders.db

# === Smart Home (Home Assistant) — Optional ===
HASS_URL=http://homeassistant.local:8123
HASS_TOKEN=
